<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="application.LeaderboardController"
           prefWidth="1000" prefHeight="600"
           style="-fx-background-color: #dcdcdc;">

    <VBox alignment="TOP_LEFT" spacing="20"
          maxWidth="750" maxHeight="450"
          style="-fx-border-color: black; -fx-border-width: 3; -fx-background-color: #efefef; -fx-padding: 30;">

        <Label text="Leaderboard:">
            <font><Font size="32"/></font>
        </Label>

        <HBox spacing="180">
            <Label text="Name">
                <font><Font size="26"/></font>
            </Label>
            <Label text="Savings">
                <font><Font size="26"/></font>
            </Label>
        </HBox>

        <HBox spacing="180">
            <Label fx:id="firstName" text="1. ---">
                <font><Font size="24"/></font>
            </Label>
            <Label fx:id="firstSavings" text="0">
                <font><Font size="24"/></font>
            </Label>
        </HBox>

        <HBox spacing="180">
            <Label fx:id="secondName" text="2. ---">
                <font><Font size="24"/></font>
            </Label>
            <Label fx:id="secondSavings" text="0">
                <font><Font size="24"/></font>
            </Label>
        </HBox>

        <HBox spacing="180">
            <Label fx:id="thirdName" text="3. ---">
                <font><Font size="24"/></font>
            </Label>
            <Label fx:id="thirdSavings" text="0">
                <font><Font size="24"/></font>
            </Label>
        </HBox>

        <Button text="Back to Menu"
                onAction="#handleBack"
                prefWidth="220" prefHeight="50"
                style="-fx-font-size: 20; -fx-border-color: black; -fx-border-width: 2; -fx-background-color: #efefef;"/>

    </VBox>
</StackPane>